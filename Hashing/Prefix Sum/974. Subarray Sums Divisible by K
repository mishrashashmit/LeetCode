//similar to problem 523
class Solution {
public:
    int subarraysDivByK(vector<int>& nums, int k) {
        unordered_map<int , int> mp; //key = remainder | value = frequency of remainder
        int currSum=0;
        mp[0]=1; //not entered the array yet
        int ans=0; //stores valid subarrays

        for(int i=0; i < nums.size(); i++){
            //compute prefix sum
            currSum+=nums[i];

            //compute remainder
            int rem=currSum%k;

            //negative to positive
            if(rem<0)
                rem+=k;
            
            ans+=mp[rem];
            mp[rem]++;
        }
        return ans;
    }
};
