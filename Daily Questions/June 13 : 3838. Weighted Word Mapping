class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        // word weight -> %26 -> reverse map (0=z, 25=a)
        string ans;
        for(string &word : words){
            int sum = 0;
            // calculate word weight
            for(char ch : word){
                sum += weights[ch - 'a'];
            }
            // reverse alphabet mapping
            ans.push_back('z' - (sum % 26));
        }
        return ans;
    }
};
