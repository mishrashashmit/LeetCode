class Solution {
public:
    double angleClock(int hour, int minutes) {
        hour %= 12;

        double minuteAngle = minutes * 6.0;  // Angles of both hands
        double hourAngle = hour * 30.0 + minutes * 0.5;

        double diff = abs(hourAngle - minuteAngle);  // Absolute difference

        return min(diff, 360.0 - diff);      // Return smaller angle
    }
};


//Minute hand = minutes × 6,
//Hour hand = hour × 30 + minutes × 0.5,
//answer = min(diff, 360 - diff).
