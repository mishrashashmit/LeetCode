class Solution {
public:
    char processStr(string s, long long k) {
        int n = s.size();
        const long long LIM = (long long)1e15 + 5;

        vector<long long> len(n + 1, 0);

        // Compute lengths after each operation
        for (int i = 0; i < n; i++) {
            long long cur = len[i];

            if (islower(s[i])) {
                len[i + 1] = min(LIM, cur + 1);
            }
            else if (s[i] == '*') {
                len[i + 1] = max(0LL, cur - 1);
            }
            else if (s[i] == '#') {
                len[i + 1] = min(LIM, cur * 2);
            }
            else { // '%'
                len[i + 1] = cur;
            }
        }

        long long L = len[n];
        if (k >= L) return '.';

        // Walk backwards
        for (int i = n - 1; i >= 0; i--) {
            char ch = s[i];
            long long before = len[i];
            long long after = len[i + 1];

            if (islower(ch)) {
                if (k == before) return ch;
            }
            else if (ch == '*') {
                // Deleted character can never be reached
                // since k < after <= before - 1.
            }
            else if (ch == '#') {
                if (before > 0)
                    k %= before;
            }
            else { // '%'
                if (after > 0)
                    k = after - 1 - k;
            }
        }

        return '.';
    }
};
